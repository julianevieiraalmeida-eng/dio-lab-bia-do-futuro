        "import pandas as pd\n",
        "import google.generativeai as genai\n",
        "from google.colab import userdata\n",
        "import warnings\n",
        "\n",
        "# Silenciador de avisos\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# 1. Recuperando a chave\n",
        "API_KEY = userdata.get('GEMINI_API_KEY')\n",
        "genai.configure(api_key=API_KEY)\n",
        "\n",
        "print(\"🔍 Buscando o modelo correto nos servidores do Google...\")\n",
        "\n",
        "# 2. MODO ENGENHARIA: Descobrindo o nome exato liberado para sua chave\n",
        "modelo_exato = None\n",
        "for m in genai.list_models():\n",
        "    # Procuramos o modelo mais rápido ('flash') que suporta geração de texto\n",
        "    if 'generateContent' in m.supported_generation_methods and 'flash' in m.name:\n",
        "        modelo_exato = m.name.replace('models/', '') # Limpa o nome para o formato correto\n",
        "        break\n",
        "\n",
        "# Fallback de segurança caso não ache o flash\n",
        "if not modelo_exato:\n",
        "    modelo_exato = 'gemini-pro'\n",
        "\n",
        "print(f\"✅ Conectado com sucesso ao motor: {modelo_exato}\\n\")\n",
        "\n",
        "# 3. Lendo os dados\n",
        "df_transacoes = pd.read_csv('data/transacoes.csv')\n",
        "\n",
        "# 4. O System Prompt (A Alma do Dante)\n",
        "SYSTEM_PROMPT = \"\"\"\n",
        "Você é o Dante, o \"Veterano do Inferno\" da universidade.\n",
        "Sua missão é ajudar estudantes universitários a organizar o \"Mapa do Inferno\" (orçamento mensal) com foco em garantir o essencial e viabilizar metas acadêmicas.\n",
        "Tom de voz: Acolhedor, cômico, irônico (no bom sentido) e realista. Use gírias universitárias (RU, calouro, xerox, bolsa).\n",
        "Regra Crítica: Use APENAS os dados do contexto para basear sua resposta matemática. Não invente valores.\n",
        "\"\"\"\n",
        "\n",
        "# Inicializando a IA com o modelo que acabamos de descobrir\n",
        "model = genai.GenerativeModel(\n",
        "    model_name=modelo_exato,\n",
        "    system_instruction=SYSTEM_PROMPT\n",
        ")\n",
        "\n",
        "# 5. A Função de Conversa\n",
        "def falar_com_dante(mensagem_usuario):\n",
        "    print(\"Processando o Mapa do Inferno...\\n\")\n",
        "\n",
        "    # Fazendo a matemática básica com o seu CSV\n",
        "    entradas = df_transacoes[df_transacoes['tipo'] == 'entrada']['valor'].sum()\n",
        "    saidas = df_transacoes[df_transacoes['tipo'] == 'saida']['valor'].sum()\n",
        "    saldo_atual = entradas - saidas\n",
        "\n",
        "    # Formatando as últimas 3 transações para a IA ler\n",
        "    ultimas_transacoes = df_transacoes.tail(3)[['data', 'descricao', 'valor']].to_string(index=False)\n",
        "\n",
        "    # O Contexto RAG\n",
        "    prompt_completo = f\"\"\"\n",
        "    <CONTEXTO_SISTEMA>\n",
        "    DADOS MATEMÁTICOS ATUAIS:\n",
        "    - Saldo Real Calculado: R$ {saldo_atual:.2f}\n",
        "\n",
        "    ÚLTIMAS TRANSAÇÕES:\n",
        "    {ultimas_transacoes}\n",
        "    </CONTEXTO_SISTEMA>\n",
        "\n",
        "    <MENSAGEM_USUARIO>\n",
        "    {mensagem_usuario}\n",
        "    </MENSAGEM_USUARIO>\n",
        "    \"\"\"\n",
        "\n",
        "    # Enviando para o motor\n",
        "    try:\n",
        "        response = model.generate_content(prompt_completo)\n",
        "        print(f\"👤 Você: {mensagem_usuario}\")\n",
        "        print(f\"🔥 Dante: {response.text}\")\n",
        "        print(\"-\" * 60)\n",
        "    except Exception as e:\n",
        "        print(f\"❌ Erro de processamento: {e}\")\n",
        "\n",
        "# 6. O Teste de Fogo!\n",
        "falar_com_dante(\"Dante, me diz a real: com esse meu saldo atual e os meus gastos, dá pra pagar o congresso de 80 reais ou eu vou falir?\")"
      ],
